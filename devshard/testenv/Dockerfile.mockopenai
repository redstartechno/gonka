# Production-shape mock-openai image (Phase 5b).
# Build context: repo root (../.. from testenv/).
FROM golang:1.24-alpine AS build
RUN apk add --no-cache git ca-certificates
COPY common/ /src/common
COPY inference-chain/ /src/inference-chain
WORKDIR /src/devshard
COPY devshard/go.mod devshard/go.sum ./
RUN go mod download
COPY devshard/ .
RUN CGO_ENABLED=0 go build -o /mockopenai ./testenv/cmd/mockopenai

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
COPY --from=build /mockopenai /usr/local/bin/mockopenai
ENTRYPOINT ["mockopenai"]
